[0.038707, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.039488, "o", "\u001b[1m\u001b[0;36m"]
[0.044462, "o", "  _     _           _ _\r\n | |__ (_)_ __ ___ (_) |_ ___ _   _\r\n | '_ \\| | '_ ` _ \\| | __/ __| | | |\r\n | | | | | | | | | | | |_\\__ \\ |_| |\r\n |_| |_|_|_| |_| |_|_|\\__|___/\\__,_|\r\n\r\n age-based secrets management\r\n"]
[0.045038, "o", "\u001b[0m\r\n"]
[0.855717, "o", "\r\n\u001b[0;36m\u001b[1m# ── 1. Help ──\u001b[0m\r\n\r\n"]
[1.167421, "o", "\u001b[1m\u001b[0;32m$ \u001b[0m\u001b[1mh"]
[1.199449, "o", "i"]
[1.231213, "o", "m"]
