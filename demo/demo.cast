[48.1800, "o", "// =============================================================================\r\n// AUTO-GENERATED by `himitsu codegen` \u2014 do not edit manually.\r\n// (environment: prod)\r\n// =============================================================================\r\n\r\n/** All environments discovered in the secret store. */\r\nexport type HimitsuEnvironment =\r\n  | \"common\"\r\n  | \"dev\"\r\n  | \"prod\";\r\n\r\n/** All secret key names. */\r\nexport type HimitsuKey =\r\n  | \"API_BASE_URL\"\r\n  | \"API_KEY\"\r\n  | \"DB_PASSWORD\";\r\n\r\n/** Typed interface for secret values. */\r\nexport interface HimitsuSecrets {\r\n  readonly apiBaseUrl: string;\r\n  readonly apiKey: string;\r\n  readonly dbPassword: string;\r\n}\r\n\r\n/** All secret key names as a constant array. */\r\nexport const HIMITSU_KEYS = [\r\n  \"API_BASE_URL\",\r\n  \"API_KEY\",\r\n  \"DB_PASSWORD\",\r\n] as const satisfies readonly HimitsuKey[];\r\n\r\n/** Secret keys available in each environment. */\r\nexport const HIMITSU_KEYS_BY_ENV: Record<HimitsuEnvironment, readonly string[]> = {\r\n  \"common\": [\r\n    \"API_BASE_URL\",\r\n  ],\r\n  \"dev\": [\r\n    \"DB_PASSWORD\",\r\n  ],\r\n  \"prod\": [\r\n    \"API_KEY\",\r\n    \"DB_PASSWORD\",\r\n  ],\r\n};\r\n"]
