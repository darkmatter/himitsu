[0.1000, "o", "\r\n"]
[0.1000, "o", " age-based secrets management\r\n"]
[0.1000, "o", "\u001b[0m\r\n"]
[1.5000, "o", "\r\n"]
[1.5000, "o", "\u001b[0;36m\u001b[1m# \u2500\u2500 1. Help \u2500\u2500\u001b[0m\r\n"]
[1.5000, "o", "\r\n"]
[1.8000, "o", "\u001b[1m\u001b[0;32m$ \u001b[0m\u001b[1m"]
[1.8500, "o", "h"]
[1.8750, "o", "i"]
[1.9000, "o", "m"]
