[50.0850, "o", "// =============================================================================\r\n// AUTO-GENERATED by `himitsu codegen` \u2014 do not edit manually.\r\n// (environment: prod)\r\n// =============================================================================\r\n\r\npackage secrets\r\n\r\n// Environments discovered in the secret store.\r\nconst (\r\n\tEnvCommon = \"common\"\r\n\tEnvDev = \"dev\"\r\n\tEnvProd = \"prod\"\r\n)\r\n\r\n// Secret key name constants.\r\nconst (\r\n\tKeyApiBaseUrl = \"API_BASE_URL\"\r\n\tKeyApiKey = \"API_KEY\"\r\n\tKeyDbPassword = \"DB_PASSWORD\"\r\n)\r\n\r\n// HimitsuSecrets holds typed secret values.\r\ntype HimitsuSecrets struct {\r\n\tApiBaseUrl string `json:\"API_BASE_URL\" yaml:\"API_BASE_URL\"`\r\n\tApiKey string `json:\"API_KEY\" yaml:\"API_KEY\"`\r\n\tDbPassword string `json:\"DB_PASSWORD\" yaml:\"DB_PASSWORD\"`\r\n}\r\n\r\n// AllKeys contains every secret key name.\r\nvar AllKeys = []string{\r\n\t\"API_BASE_URL\",\r\n\t\"API_KEY\",\r\n\t\"DB_PASSWORD\",\r\n}\r\n"]
