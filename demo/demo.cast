[1.548418, "o", "l"]
[1.580158, "o", "p"]
[1.613112, "o", "\u001b[0m\r\n"]
[1.736133, "o", "Age-based secrets management with transport-agnostic sharing\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m \u001b[1mhimitsu\u001b[0m [OPTIONS] <COMMAND>\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1minit\u001b[0m       Initialize a new himitsu store at ~/.himitsu\r\n  \u001b[1mset\u001b[0m        Set a secret value\r\n  \u001b[1mget\u001b[0m        Get a secret value\r\n  \u001b[1mls\u001b[0m         List environments or secrets\r\n  \u001b[1mencrypt\u001b[0m    Re-encrypt secrets for current recipients\r\n  \u001b[1mdecrypt\u001b[0m    Decrypt secrets (not supported - secrets are never stored in plaintext)\r\n  \u001b[1msync\u001b[0m       Sync encrypted secrets to project destinations\r\n  \u001b[1msearch\u001b[0m     Search secrets across remotes\r\n  \u001b[1mrecipient\u001b[0m  Manage recipients\r\n  \u001b[1mgroup\u001b[0m      Manage recipient groups\r\n  \u001b[1mremote\u001b[0m     Manage git-backed remotes\r\n  \u001b[1mshare\u001b[0m      Share secrets with external recipients\r\n  \u001b[1minbox\u001b[0m      Manage the incoming secret inbox\r\n  \u001b[1mschema\u001b[0m     Generate and manage JSON schemas\r\n  \u001b[1mcodegen\u001b[0m    Generate typed config code from secrets\r\n  \u001b[1mimport\u001b[0m     Import secre"]
[1.736192, "o", "ts from external stores\r\n  \u001b[1mhelp\u001b[0m       Print this message or the help of the given subcommand(s)\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n  \u001b[1m-r\u001b[0m, \u001b[1m--remote\u001b[0m <REMOTE>  Target remote (org/repo). Overrides project binding and default remote\r\n  \u001b[1m-v\u001b[0m, \u001b[1m--verbose\u001b[0m...       Increase log verbosity (-v for debug, -vv for trace)\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m             Print help\r\n  \u001b[1m-V\u001b[0m, \u001b[1m--version\u001b[0m          Print version\r\n"]
[1.737131, "o", "\r\n"]
