[51.9900, "o", "# =============================================================================\r\n# AUTO-GENERATED by `himitsu codegen` \u2014 do not edit manually.\r\n# (environment: prod)\r\n# =============================================================================\r\n\r\nfrom __future__ import annotations\r\n\r\nfrom dataclasses import dataclass\r\nfrom enum import Enum\r\nfrom typing import ClassVar, FrozenSet\r\n\r\n\r\nclass HimitsuEnvironment(str, Enum):\r\n    \"\"\"Environments discovered in the secret store.\"\"\"\r\n\r\n    COMMON = \"common\"\r\n    DEV = \"dev\"\r\n    PROD = \"prod\"\r\n\r\n\r\n@dataclass(frozen=True)\r\nclass HimitsuSecrets:\r\n    \"\"\"Typed secret values.\"\"\"\r\n\r\n    api_base_url: str\r\n    api_key: str\r\n    db_password: str\r\n\r\n    ALL_KEYS: ClassVar[FrozenSet[str]] = frozenset({\r\n        \"API_BASE_URL\",\r\n        \"API_KEY\",\r\n        \"DB_PASSWORD\",\r\n    })\r\n\r\n\r\nKEYS_BY_ENV: dict[HimitsuEnvironment, frozenset[str]] = {\r\n    HimitsuEnvironment.COMMON: frozenset({\r\n        \"API_BASE_URL\",\r\n    }),\r\n    HimitsuEnvironment.DEV: frozenset({\r\n        \"DB_PASSWORD\",\r\n    }),\r\n    HimitsuEnvironment.PROD: frozenset({\r\n        \"API_KEY\",\r\n        \"DB_PASSWORD\",\r\n    }),\r\n}\r\n"]
