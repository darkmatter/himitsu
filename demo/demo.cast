[53.8450, "o", "// =============================================================================\r\n// AUTO-GENERATED by `himitsu codegen` \u2014 do not edit manually.\r\n// (environment: prod)\r\n// =============================================================================\r\n\r\n#![allow(dead_code)]\r\n\r\n/// Environments discovered in the secret store.\r\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\r\npub enum HimitsuEnvironment {\r\n    /// `common`\r\n    Common,\r\n    /// `dev`\r\n    Dev,\r\n    /// `prod`\r\n    Prod,\r\n}\r\n\r\nimpl HimitsuEnvironment {\r\n    /// The canonical string name of this environment.\r\n    pub const fn as_str(&self) -> &'static str {\r\n        match self {\r\n            Self::Common => \"common\",\r\n            Self::Dev => \"dev\",\r\n            Self::Prod => \"prod\",\r\n        }\r\n    }\r\n}\r\n\r\n/// Secret key names.\r\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\r\npub enum HimitsuKey {\r\n    /// `API_BASE_URL`\r\n    ApiBaseUrl,\r\n    /// `API_KEY`\r\n    ApiKey,\r\n    /// `DB_PASSWORD`\r\n    DbPassword,\r\n}\r\n\r\nimpl HimitsuKey {\r\n    /// The canonical string name of this key.\r\n    pub const fn as_str(&self) -> &'static str {\r\n        match self {\r\n            Self::ApiBaseUrl => \"API_BASE_URL\",\r\n            Self::ApiKey => \"API_KEY\",\r\n            Self::DbPassword => \"DB_PASSWORD\",\r\n        }\r\n    }\r\n}\r\n\r\n/// Typed container for secret values.\r\npub struct HimitsuSecrets {\r\n    /// `API_BASE_URL`\r\n    pub api_base_url: String,\r\n    /// `API_KEY`\r\n    pub api_key: String,\r\n    /// `DB_PASSWORD`\r\n    pub db_password: String,\r\n}\r\n\r\n/// All secret key names.\r\npub const ALL_KEYS: [HimitsuKey; 3] = [\r\n    HimitsuKey::ApiBaseUrl,\r\n    HimitsuKey::ApiKey,\r\n    HimitsuKey::DbPassword,\r\n];\r\n\r\n/// All secret key names as string slices.\r\npub const ALL_KEY_NAMES: [&str; 3] = [\r\n    \"API_BASE_URL\",\r\n    \"API_KEY\",\r\n    \"DB_PASSWORD\",\r\n];\r\n"]
